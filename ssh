#	"rgb:F6/EE/F6"
#	"rgb:F6/EE/F2"
#)

NUM_COLORS=${#LIGHT_COLORS[@]}

# ---------- Parse ssh arguments to extract user and host ----------
parse_target() {
    local user="" host=""
    local skip_next=0
    for arg in "$@"; do
        if [[ $skip_next -eq 1 ]]; then
            skip_next=0
            continue
        fi
        case "$arg" in
            -l)
                skip_next=1
                ;;
            -p|-o|-F|-i|-J|-w|-c|-m|-E|-L|-R|-D|-O|-S|-W)
                skip_next=1
                ;;
            -*)
                ;;
            *)
                if [[ "$arg" == *"@"* ]]; then
                    user="${arg%%@*}"
                    host="${arg#*@}"
                else
                    host="$arg"
                fi
                break
                ;;
        esac
    done

    local prev_was_l=0
    for arg in "$@"; do
        if [[ $prev_was_l -eq 1 ]]; then
            user="$arg"
            prev_was_l=0
            continue
        fi
        [[ "$arg" == "-l" ]] && prev_was_l=1
    done

    [[ -z "$user" ]] && user="$USER"
    echo "$user@$host"
}

target=$(parse_target "$@")
if [[ -z "$target" || "$target" == "@" ]] || [[ ! -e /dev/tty ]] || [[ "$(uname -s)" != "Darwin" ]]; then
    exec /usr/bin/ssh "$@"
fi

# Deterministic index based on user@host
hash=$(printf "%s" "$target" | cksum | cut -d' ' -f1)
index=$(( hash % NUM_COLORS ))
bg_color="${LIGHT_COLORS[$index]}"

# ---------- Trap to restore background ----------
restore_bg() {
    printf '\e]111\a' >/dev/tty 2>/dev/null  # reset background to default
    trap - EXIT INT TERM
}
trap restore_bg EXIT INT TERM

# Apply the chosen light background
printf '\e]11;%s\a' "$bg_color" >/dev/tty 2>/dev/null

# Run the real ssh
/usr/bin/ssh "$@"
ret=$?

restore_bg
exit $ret
